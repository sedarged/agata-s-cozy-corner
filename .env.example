# Agata — environment template.
# Copy to .env (never commit .env) and fill in what you need.
#   cp .env.example .env
#
# IMPORTANT: every value below is OPTIONAL. The app runs fully without any of
# them — books, notes, handwriting, reading sessions and backups are all stored
# locally in the browser. The variables only enable the Gigi assistant and let
# you tune the server port/host.

# ── Gigi assistant (AI) — OPTIONAL ──────────────────────────────────────────
# Without a key Gigi simply shows "nie skonfigurowana" and the rest of the app
# is unaffected.

# Primary provider. Create a key at https://platform.openai.com/api-keys
# (used model: gpt-4o-mini).
OPENAI_API_KEY=

# Fallback provider (Lovable AI gateway). Only used if OPENAI_API_KEY is empty.
LOVABLE_API_KEY=

# Optional shared secret. If set, POST /api/chat requires header
#   X-Gigi-Key: <this value>
# Useful as a minimal guard if the server is reachable beyond your private network.
GIGI_SECRET=

# ── Gigi via OAuth ChatGPT (Faza 2) — OPTIONAL ─────────────────────────────
# When the user clicks "Połącz ChatGPT" in Settings, the OAuth flow uses these
# variables. Both have safe defaults so the UI is reachable without any extra
# setup; the actual exchange happens against `auth.openai.com`.
#
# OAuth client id (Codex public client — `codex-rs/cli/src/main.rs`).
CHATGPT_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# Loopback callback URL used for the browser flow. On the VPS this should be
# the same hostname as the user-facing site (since Caddy will proxy /api/*).
CHATGPT_OAUTH_REDIRECT_URI=http://127.0.0.1:3001/api/chatgpt/callback

# AES-256 key for encrypting the OAuth token at rest. Generate with:
#   openssl rand -base64 32
# Without this variable, the OAuth flow still works in-memory but tokens
# cannot be persisted across server restarts.
GIGI_TOKEN_KEY=

# Override the model id for the chatgpt provider (default: gpt-5).
GIGI_CHATGPT_MODEL=gpt-5

# ── Server (Nitro node-server) ──────────────────────────────────────────────
# Port the Node server listens on. Default 3000.
PORT=3000

# Bind address. Use 127.0.0.1 when a reverse proxy (Caddy) sits on the same host,
# or 0.0.0.0 to expose directly. Nitro also accepts NITRO_HOST/NITRO_PORT.
HOST=127.0.0.1
