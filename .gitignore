!.env.example

# Tool scratch dirs (Playwright MCP, code-review receipts)
.playwright-mcp/
review-receipts/
test-results/
playwright-report/

# Debug screenshots accumulated in repo root from walkthroughs, audits,
# and ad-hoc Playwright runs. Permanent documentation screenshots belong
# in `docs/` — see the `!` exception below.
*.png
!/docs/**/*.png

# Sandbox-only loader for a prebuilt better-sqlite3 binary when
# node_modules was installed by root and can't be replaced locally.
# Production runs have a working prebuilt, so this script is dead code
# outside this sandbox.
scripts/load-rebuilt-bsqlite3.cjs

# Claude Code user-level config — must NEVER be committed. Contains
# live API keys (ANTHROPIC_AUTH_TOKEN etc.) and must live in ~/.claude/
settings.json

# Per-project Claude metadata (tier pins) and internal superpowers
# scratch notes (new untracked plans only) — not public repo content.
# src/routeTree.gen.ts is the deliberate exception (regenerated by
# the TanStack Router Vite plugin and committed with every new route).
# The one tracked plan (`2026-06-25-openai-api-key.md`, landed in 0b846b5)
# is explicitly allow-listed via the negation rule below.
.claude/
docs/superpowers/plans/*
!docs/superpowers/plans/2026-06-25-openai-api-key.md
